generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt      DateTime @default(now())
  records        Record[]
  budgets        Budget[]
  pushSubscriptions PushSubscription[]
}

model Record {
  id        String   @id @default(cuid())
  userId    String
  category  String
  summary   String
  details   String
  emoji     String   @default("📌")
  createdAt DateTime @default(now())
  routineId String?
  deletedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  finance   Finance?
  sport     Sport?
  task      Task?
  note      Note?
  mood      Mood?

  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@index([routineId])
  @@index([deletedAt])
}

model Finance {
  id       String @id @default(cuid())
  recordId String @unique
  record   Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
  amount   Float
  currency String @default("RUB")
  type     String @default("expense")
}

model Sport {
  id       String @id @default(cuid())
  recordId String @unique
  record   Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
  duration Int?
  sets     Int?
  reps     Int?
  distance Float?
}

model Task {
  id       String    @id @default(cuid())
  recordId String    @unique
  record   Record    @relation(fields: [recordId], references: [id], onDelete: Cascade)
  deadline String?
  priority String    @default("medium")
  done     Boolean   @default(false)
  doneAt   DateTime?
  recurrence String?
}

model Note {
  id       String  @id @default(cuid())
  recordId String  @unique
  record   Record  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  pinned   Boolean @default(false)
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  category  String
  amount    Float
  period    String   @default("month")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period])
  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Mood {
  id       String @id @default(cuid())
  recordId String @unique
  record   Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
  score    Int
}
